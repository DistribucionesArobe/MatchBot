# MatchBot Environment Variables
# Copy to .env and fill in your values

DATABASE_URL=postgresql://matchbot:matchbot@localhost:5432/matchbot

# WhatsApp Cloud API (configured per-club in DB, but default here)
WA_VERIFY_TOKEN=your-webhook-verify-token

# App
APP_URL=https://matchbot.live
SECRET_KEY=change-me-to-a-random-string
DEBUG=true

# Stripe (optional, for card payments)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
